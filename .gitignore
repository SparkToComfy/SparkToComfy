# Local environment files
.env
.env.*
!.env.example
.local-backup/

# Runtime config with secrets/private prompts
config/backend/config.yaml
config/backend/config.d/*.yaml
config/backend/prompts/*.md
config/backend/prompts/*.yaml
config/backend/prompts/*.json
config/backend/prompts/fewshot/*.json
config/backend/prompts/modules/*.md
config/bot/*.yaml

# Runtime data
data/*
!data/.gitkeep

# Keep examples
!config/backend/config.yaml.example
!config/backend/config.d/*.yaml.example
!config/backend/prompts/*.md.example
!config/backend/prompts/*.yaml.example
!config/backend/prompts/*.json.example
!config/backend/prompts/fewshot/*.json.example
!config/backend/prompts/modules/*.md.example
!config/bot/*.yaml.example

# Logs / OS / IDE
*.log
.vscode/
.idea/
.DS_Store
Thumbs.db
