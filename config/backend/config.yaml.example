# Copy this file to config/backend/config.yaml before running docker compose.
# The backend container sees this directory as /config.
#
# Each file listed here must exist under /config and must contain exactly one
# top-level backend runtime config section.

config_files:
  - config.d/storage.yaml
  - config.d/rate-limit.yaml
  - config.d/generation-queue.yaml
  - config.d/request-capture.yaml
  - config.d/auth.yaml
  - config.d/image-generation.yaml
  - config.d/provider-streaming.yaml
  - config.d/providers.yaml
