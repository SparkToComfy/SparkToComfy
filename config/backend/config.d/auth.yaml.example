# Local backend-owned user authentication. Invite codes gate registration.
auth:
  enabled: true
  cookie_name: sparktocomfy_session
  cookie_secure: auto
  cookie_samesite: lax
  access_token_ttl_seconds: 900
  session_ttl_seconds: 2592000
  password:
    min_length: 12
    max_length: 256
    hash_algorithm: argon2id
  login_rate_limit:
    max_attempts: 5
    window_seconds: 300
  webauthn:
    # Keep passkey/WebAuthn disabled for the first VM deployment. While this is
    # false, rp_id and origins do not need to match the public Cloudflared
    # domain.
    enabled: false
    rp_id: localhost
    rp_name: SparkToComfy
    origins:
      - http://localhost:5173
    challenge_ttl_seconds: 300
    timeout_ms: 60000
