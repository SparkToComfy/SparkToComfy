# ComfyUI image gateway. Disabled by default so a fresh VM deployment can start
# without a ComfyUI runtime or workflow JSON mounted under /config.
image_generation:
  enabled: false
  base_url: http://127.0.0.1:8188
  client_id: sparktocomfy-backend
  workflow_directory: /config/comfyUI
  timeout_seconds: 300
  health_timeout_seconds: 2.0
  health_poll_interval_seconds: 5.0
  poll_interval_seconds: 1.0
  max_poll_attempts: 300
  preview_max_bytes: 2000000
  queue:
    max_pending_jobs: 10
    max_running_jobs: 1
    finished_ttl_seconds: 1800
  outputs:
    comfyui_output_directory: null
    output_discovery:
      strategy: history_output_then_pattern
      subfolder: API
      filename_pattern: "*{model_stem}-{seed}*"
      lookback_seconds: 10.0
  workflow: null
