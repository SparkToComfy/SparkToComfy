# config/config.yaml.example - main runtime config (documentation copy)
#
# Setup:
# 1. Copy this file to config/config.yaml and edit your values.
# 2. Do the same for config/providers.yaml.example and
#    config/image-options.yaml.example.
# 3. The ComfyUI workflow prompt is always read from the fixed, tracked
#    config/workflow.json; the ComfyUI address comes from the COMFYUI_BASE_URL
#    environment variable.
#
# The backend never falls back to .example files: a missing config file is an
# explicit startup error. See docs/guidelines/ for field-by-field guides.
#
# Sections in this file: auth, generation_queue, image_generation.

# Local backend-owned user authentication. Invite codes gate registration.
# CORS and WebAuthn browser origins come from the FRONTEND_ORIGINS
# environment variable.
auth:
  enabled: true
  cookie_name: sparktocomfy_session
  cookie_secure: auto
  cookie_samesite: lax
  access_token_ttl_seconds: 900
  session_ttl_seconds: 2592000
  password:
    min_length: 12
    max_length: 256
    hash_algorithm: argon2id
  login_rate_limit:
    max_attempts: 5
    window_seconds: 300
  webauthn:
    enabled: true
    rp_id: localhost
    rp_name: SparkToComfy
    challenge_ttl_seconds: 300
    timeout_ms: 60000

# Text generation queue limits, prompt count cap, and ETA metrics settings.
generation_queue:
  max_pending_jobs: 25
  max_running_jobs: 5
  max_generation_count: 3
  default_provider_concurrency: 2
  provider_concurrency:
    openai: 2
    anthropic: 2
  runtime_metrics:
    default_generation_seconds: 180
    max_samples_per_bucket: 50

# ComfyUI image gateway. Disabled by default; automated tests do not require a
# live ComfyUI runtime. The ComfyUI address comes from the COMFYUI_BASE_URL
# environment variable, the workflow prompt from config/workflow.json, and the
# public image options from config/image-options.yaml.
image_generation:
  enabled: false
  client_id: sparktocomfy-backend
  timeout_seconds: 300
  health_timeout_seconds: 2.0
  health_poll_interval_seconds: 5.0
  poll_interval_seconds: 1.0
  max_poll_attempts: 300
  preview_max_bytes: 2000000
  finished_ttl_seconds: 1800
  outputs:
    # The backend writes "{sub_folder}/{filename}" into the save-image node's
    # filename_prefix before each ComfyUI submit. Final images are served to
    # the frontend as same-origin view-proxy URLs streamed through the backend:
    # /v1/images/view?filename=...&subfolder=...&type=output
    # The view route only accepts subfolder values equal to sub_folder below.
    # sub_folder is the ComfyUI output subfolder; filename is the file prefix
    # (ComfyUI tokens such as %date:...%, %model%, and %seed% are expanded by
    # the save node).
    sub_folder: API
    filename: "%date:yyyy-MM-dd-hh-mm-ss%_%model%-%seed%"
  workflow:
    # Node role mappings into the fixed config/workflow.json prompt. The
    # single workflow contains both the base image path and the upscale
    # nodes; the backend changes nodes.output_switch to route either path.
    nodes:
      size: "20736"
      base_model: "20735:6196"
      lora_loader: "20737"
      lora_trigger: "20738"
      quality_prompt: "20739"
      positive_prompt: "20740"
      negative_prompt: "20741"
      sampler: "20742"
      # The save node must publish its saved images as type "output" refs in
      # ComfyUI history; SaveImagePlus only does this when enable_preview is
      # true in the workflow JSON. Without refs, image jobs fail with
      # IMAGE_OUTPUT_NOT_FOUND even though the file was saved.
      save_image: "20745"
      output_switch: "20753"
    upscale:
      disabled_source:
        - "20743"
        - 0
      enabled_source:
        - "20752"
        - 0
